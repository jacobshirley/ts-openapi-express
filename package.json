{
    "name": "ts-openapi-express-monorepo",
    "version": "1.0.6",
    "private": true,
    "type": "module",
    "description": "Type-safe Express.js integration for OpenAPI specifications with request/response validation",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "compile": "pnpm -r run compile && pnpm compile:test",
        "compile:test": "tsc --noEmit",
        "prepublish": "pnpm -r run compile",
        "test": "pnpm -r --no-sort run test",
        "prepare": "husky || true",
        "lint:staged": "lint-staged --allow-empty",
        "lint:commit": "commitlint --edit $1",
        "format": "prettier --write '**/*.{js,ts,json,md,yaml,yml}'",
        "docs:gen": "sh -c 'pnpm docs:gen:md \"$@\" && pnpm docs:gen:html \"$@\"' --",
        "docs:gen:md": "./scripts/gen-md-docs.sh",
        "docs:gen:html": "./scripts/gen-html-docs.sh"
    },
    "keywords": [
        "openapi",
        "express",
        "typescript",
        "rest-api",
        "api",
        "validation",
        "type-safe",
        "schema-validation",
        "openapi-typescript",
        "request-validation",
        "response-validation",
        "nodejs"
    ],
    "author": "Jacob Shirley",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jacobshirley/ts-openapi-express.git"
    },
    "bugs": {
        "url": "https://github.com/jacobshirley/ts-openapi-express/issues"
    },
    "homepage": "https://jacobshirley.github.io/ts-openapi-express",
    "packageManager": "pnpm@10.28.1",
    "lint-staged": {
        "*.{js,ts,json,md}": "pnpm format"
    },
    "pnpm": {
        "overrides": {
            "typescript": "$typescript"
        },
        "packageExtensions": {
            "@vitest/browser": {
                "peerDependencies": {
                    "@vitest/runner": "*"
                }
            }
        }
    },
    "devDependencies": {
        "@commitlint/cli": "^20.1.0",
        "@commitlint/config-conventional": "^20.0.0",
        "@types/node": "^24",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.6.2",
        "tsx": "^4.20.6",
        "typedoc": "^0.28.14",
        "typedoc-plugin-markdown": "^4.9.0",
        "typescript": "5.9.3"
    }
}
