    "main": "dist/index.js",
    "directories": {
        "test": "test"
    },
    "repository": {
        "url": "https://github.com/jacobshirley/ts-openapi-express"
    },
    "bugs": {
        "url": "https://github.com/jacobshirley/ts-openapi-express/issues"
    },
