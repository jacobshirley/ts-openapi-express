        "express": "^5.0.0"
    },
    "peerDependenciesMeta": {
        "express": {
            "optional": false
        },
        "express-openapi-validator": {
            "optional": false
        }
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^22.0.0",
        "@types/supertest": "^6.0.2",
        "@types/swagger-ui-express": "^4.1.6",
        "openapi-types": "^12.1.0",
