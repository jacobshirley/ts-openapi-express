{
    "name": "ts-openapi-express",
    "type": "module",
    "version": "1.0.0",
    "description": "",
    "main": "dist/index.js",
    "directories": {
        "test": "test"
    },
    "keywords": [
        "openapi",
        "express",
        "typescript",
        "rest-api",
        "api",
        "validation",
        "type-safe",
        "schema-validation",
        "openapi-typescript",
        "request-validation",
        "response-validation",
        "nodejs"
    ],
    "scripts": {
        "test": "pnpm test:unit",
        "test:unit": "pnpm test:compile:spec && vitest run",
        "test:compile:spec": "openapi-typescript test/unit/openapi.test.yaml --output test/unit/test-schema.ts",
        "compile": "tsc -p tsconfig.prod.json",
        "watch": "tsc -p tsconfig.prod.json --watch"
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "express": "^5.0.0",
        "express-openapi-validator": "^5.3.9",
        "lodash-es": "^4.17.23",
        "yaml": "^2.8.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.0",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^22.0.0",
        "@types/supertest": "^6.0.2",
        "@types/swagger-ui-express": "^4.1.6",
        "openapi-types": "^12.1.0",
        "openapi-typescript": "^7.4.1",
        "supertest": "^7.0.0",
        "typescript": "^5.0.4",
        "vitest": "^4.0.18"
    },
    "files": [
        "dist"
    ]
}
